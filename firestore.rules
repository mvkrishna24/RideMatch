rules_version = '2';

// RouteMatch chat rules. Deploy in Firebase console → Firestore → Rules.
// A chat room's participants are the two Firebase UIDs of a backend-created
// connection; only those two accounts can read or write anything in it.
service cloud.firestore {
  match /databases/{database}/documents {

    match /chats/{chatId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Room creation: the creator must include themself in participants,
      // and the room holds exactly two members.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      // Room updates (lastMessage/updatedAt): participants only, and the
      // participant list itself can never be changed.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;

        // Messages are immutable — no edits, no deletes, honest history.
        allow update, delete: if false;
      }
    }

    // Everything else is off-limits.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
